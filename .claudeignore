# ===========================
# 前端
# ===========================

# 套件依賴（通常很大，Claude 不需要讀）
frontend/node_modules/

# Vite 建置產物
frontend/dist/

# ===========================
# 後端（Maven）
# ===========================

# 所有服務的編譯產出目錄
backend/**/target/

# Maven wrapper jar（二進位檔）
backend/**/mvnw
backend/**/mvnw.cmd
backend/**/.mvn/

# ===========================
# 環境變數 / 機敏設定
# ===========================

.env
.env.*
!.env.example

# ===========================
# 資料庫 Volume 資料
# ===========================

database/data/

# ===========================
# Log 與暫存檔
# ===========================

**/*.log
**/*.log.*
**/logs/
**/tmp/
**/.tmp/

# ===========================
# IDE / 編輯器設定
# ===========================

**/.idea/
**/.vscode/
**/*.iml

# ===========================
# 文件附件（Word / Excel）
# ===========================

docs/*.docx
docs/*.xlsx
docs/~$*

# ===========================
# Docker 資料 Volume（本機掛載）
# ===========================

**/docker-volumes/
