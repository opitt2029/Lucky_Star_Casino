# =========================
# Project
# =========================
# ⚠️ 密鑰規則：所有值為 CHANGE_ME 的變數都是佔位符，複製成 .env 後必須換成
#    自己生成的隨機值，不要沿用任何範本值或別人的值（生成方式與輪替 SOP 見
#    docs/security/secret-rotation.md）：
#      Git Bash / macOS / Linux：openssl rand -base64 48
#    佔位符不到 HS256 的 32 bytes 下限，直接啟動會 fail-fast（WeakKeyException），
#    這是刻意設計，避免拿範本值上線。
PROJECT_NAME=lucky_star_casino

# =========================
# MySQL
# =========================
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=lucky_star_casino
MYSQL_USER=lucky_user
MYSQL_PASSWORD=CHANGE_ME
MYSQL_HOST=localhost
MYSQL_PORT=3307

# =========================
# PostgreSQL
# =========================
POSTGRES_DB=lucky_star_casino
POSTGRES_USER=lucky_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379

# =========================
# Kafka（KRaft 模式，無 Zookeeper）
# =========================
KAFKA_PORT=9092
KAFKA_UI_PORT=8085
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KRaft 叢集 ID：固定值避免重建 volume 後 id 不一致；可用 `kafka-storage random-uuid` 另產
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# =========================
# Frontend
# =========================
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_USE_MOCK_API=false
VITE_ENABLE_DEV_TOOLS=false

# =========================
# Backend
# =========================
GATEWAY_PORT=8080
MEMBER_SERVICE_PORT=8081
WALLET_SERVICE_PORT=8082
GAME_SERVICE_PORT=8083
RANK_SERVICE_PORT=8084
ADMIN_SERVICE_PORT=8086
NOTIFICATION_SERVICE_PORT=8087

# =========================
# Secrets — 必填，無預設值（全部佔位符，生成方式見檔頭與 docs/security/secret-rotation.md）
# =========================
# JWT signing secret（HS256，≥ 64 chars 隨機字串）：openssl rand -base64 48
JWT_SECRET=CHANGE_ME
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# 後台（admin-service）獨立 JWT secret —— 與玩家 JWT_SECRET 分離（T-050），
# 兩者必須用不同的隨機值。缺了 admin-service 啟動失敗（HS256 需 ≥ 32 bytes）。
ADMIN_JWT_SECRET=CHANGE_ME
ADMIN_JWT_EXPIRY_MS=3600000
# 預設後台管理員（首次啟動播種；密碼自行生成，首登後更換）
ADMIN_SEED_ENABLED=true
ADMIN_SEED_USERNAME=superadmin
ADMIN_SEED_PASSWORD=CHANGE_ME

# 內部服務間呼叫共用密鑰：openssl rand -base64 48
# member-service 目前讀 INTERNAL_SECRET；部分服務仍讀 INTERNAL_SERVICE_SECRET。
# 兩者填「同一個」生成值，避免啟動不同 service 時缺少環境變數。
INTERNAL_SECRET=CHANGE_ME
INTERNAL_SERVICE_SECRET=CHANGE_ME

# 內部服務 URL（此為原生 mvn 開發預設值；docker compose 容器化啟動時，
# 各服務的 compose environment 區塊已覆寫成容器名，此處預設值不受影響）
MEMBER_SERVICE_URL=http://localhost:8081
WALLET_SERVICE_URL=http://localhost:8082
GAME_SERVICE_URL=http://localhost:8083
RANK_SERVICE_URL=http://localhost:8084
ADMIN_SERVICE_URL=http://localhost:8086
NOTIFICATION_SERVICE_URL=http://localhost:8087

# Gateway CORS（逗號分隔多個 origin）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# =========================
# JPA / Hibernate
# =========================
# 預設 validate（schema 由 database/*/init.sql 管理）
# 本機開發若想讓 Hibernate 自動建表，改為 update
JPA_DDL_AUTO=validate

# =========================
# Logging（本機 dev 可改 DEBUG）
# =========================
LOG_LEVEL_APP=INFO
LOG_LEVEL_SQL=OFF
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_GATEWAY=INFO
