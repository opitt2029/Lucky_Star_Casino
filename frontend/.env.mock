# e2e 專用模式：強制走 mock API（離線可跑，無需後端）。
# 以 `vite --mode mock` 載入；mode 檔優先序高於 .env.local / .env.development，
# 故可覆蓋它們的 VITE_USE_MOCK_API=false。此檔進版控，確保 CI/任何 clone 都能重現 e2e。
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_USE_MOCK_API=true
# Keep developer-only pages out of the e2e/player smoke environment.
VITE_ENABLE_DEV_TOOLS=false
